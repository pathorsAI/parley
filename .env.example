# Parley environment variables (optional, for development only)
#
# API keys for Soniox, Anthropic, and OpenRouter are normally configured in the
# in-app Settings window — you do NOT need this file for normal use.
#
# These VITE_* variables are read only as optional development defaults. Note
# that Vite inlines any VITE_* value into the frontend bundle, so never put a
# production secret here.

VITE_SONIOX_API_KEY=your-soniox-api-key
VITE_OPENROUTER_API_KEY=your-openrouter-api-key
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
