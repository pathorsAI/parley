.styles-module__VEIMVW__voiceAgent{flex-direction:column;justify-content:center;align-items:center;width:100%;height:100%;min-height:140px;display:flex;position:relative}.styles-module__VEIMVW__waveformArea{z-index:1;flex:1;justify-content:center;align-items:center;width:100%;transition:opacity .3s;display:flex;position:relative}.styles-module__VEIMVW__introText{text-align:center;pointer-events:none;z-index:3;background:#fff;border-radius:6px;justify-content:center;align-items:center;padding:0 20px;font-size:15px;font-weight:500;transition:opacity .3s;display:flex;position:absolute;inset:0;box-shadow:0 0 12px 6px #ffffffd9}.styles-module__VEIMVW__faded{opacity:0}@media (min-width:640px){.styles-module__VEIMVW__introText{font-size:17px}}.styles-module__VEIMVW__overlayCard{text-align:center;z-index:2;background:#fff;border-radius:6px;flex-direction:column;justify-content:center;align-items:center;gap:8px;padding:12px 20px;display:flex;position:absolute;inset:0;box-shadow:0 0 12px 6px #ffffffd9}.styles-module__VEIMVW__overlayTitle{color:var(--soniox-black);font-size:22px;font-weight:600}.styles-module__VEIMVW__overlaySubtitle{color:var(--soniox-black);max-width:680px;margin-bottom:5px;font-size:15px;line-height:1.4}.styles-module__VEIMVW__overlayErrorText{color:var(--soniox-red);word-break:break-word;max-width:460px;font-size:12px;font-style:italic}.styles-module__VEIMVW__overlayButtons{flex-wrap:wrap;justify-content:center;gap:8px;margin-top:4px;display:flex}.styles-module__VEIMVW__micIndicatorArea{pointer-events:none;z-index:1;justify-content:center;display:flex;position:absolute;top:22px;left:0;right:0}.styles-module__VEIMVW__transcriptionContainer{z-index:2;justify-content:center;align-items:center;display:flex;position:absolute;bottom:0;left:0;right:0}.styles-module__VEIMVW__transcriptionLine{text-align:center;word-wrap:break-word;overflow-wrap:break-word;background:#fffffff2;border-radius:6px;width:100%;padding:6px 16px;font-size:13px;line-height:1.4;box-shadow:0 0 12px 6px #ffffffd9}.styles-module__VEIMVW__textBlue{color:var(--soniox-blue-2)}.styles-module__VEIMVW__textGray{color:var(--soniox-grey)}.styles-module__VEIMVW__stateBubbleContainer{pointer-events:none;z-index:1;justify-content:center;padding:0 16px;display:flex;position:absolute;top:-10px;left:0;right:0}.styles-module__VEIMVW__stateBubble{border:1px solid rgba(var(--soniox-lightgrey-rgb), 1);box-shadow:0 2px 10px rgba(var(--soniox-darkblue-rgb), .08), 0 0 12px 6px #ffffffd9;color:var(--soniox-darkgrey);background:#fffffff5;border-radius:999px;align-items:center;gap:6px;padding:4px 12px;font-size:12px;line-height:1.4;display:inline-flex}.styles-module__VEIMVW__stateIcon{color:var(--soniox-blue-2);flex-shrink:0;justify-content:center;align-items:center;font-size:14px;display:inline-flex}.styles-module__VEIMVW__stateLabel{font-weight:500}.styles-module__VEIMVW__stateBubble[data-state=speaking] .styles-module__VEIMVW__stateLabel{color:var(--soniox-darkblue)}.styles-module__VEIMVW__thinkingDots{align-items:center;gap:3px;padding:0 1px;display:inline-flex}.styles-module__VEIMVW__thinkingDots span{background:var(--soniox-blue-2);border-radius:50%;width:4px;height:4px;animation:1.2s ease-in-out infinite both styles-module__VEIMVW__thinkingDot}.styles-module__VEIMVW__thinkingDots span:first-child{animation-delay:-.32s}.styles-module__VEIMVW__thinkingDots span:nth-child(2){animation-delay:-.16s}@keyframes styles-module__VEIMVW__thinkingDot{0%,80%,to{opacity:.4;transform:scale(.6)}40%{opacity:1;transform:scale(1)}}@media (min-width:640px){.styles-module__VEIMVW__stateBubble{padding:5px 14px;font-size:13px}.styles-module__VEIMVW__stateIcon{font-size:16px}}
